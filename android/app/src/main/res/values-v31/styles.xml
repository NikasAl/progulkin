<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+) uses the new Splash Screen API -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Темный фон splash экрана -->
        <item name="android:windowSplashScreenBackground">#000000</item>
        <!-- Splash иконка с отступами для круглой маски Android 12+ -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_android12</item>
        <!-- Длительность анимации (мс) -->
        <item name="android:windowSplashScreenAnimationDuration">200</item>
        <!-- Темный статус бар и навигация -->
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
