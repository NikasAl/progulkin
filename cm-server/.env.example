# CM Server Configuration
# Copy to .env and fill in your values

# Environment
ENV=dev
DEBUG=true

# API
HOST=0.0.0.0
PORT=8002

# YooKassa (get from https://yookassa.ru)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Redis
REDIS_URL=redis://localhost:6379/2

# Signaling Security
SIGNALING_HOST=0.0.0.0
SIGNALING_PORT=9001
SIGNALING_AUTH_SECRET=your-random-64-char-secret-here  # openssl rand -hex 32
SIGNALING_AUTH_REQUIRED=true
SIGNALING_MAX_MESSAGE_SIZE=65536
SIGNALING_RATE_LIMIT=10

# Payment limits
MIN_PAYMENT_AMOUNT=10
MAX_PAYMENT_AMOUNT=100000

# Base URL (for return URLs)
BASE_URL=https://kreagenium.ru
