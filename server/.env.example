# Пример конфигурации
# Скопируйте в .env и заполните значения

# Окружение: dev, prod
ENV=dev
DEBUG=true

# API сервер
HOST=0.0.0.0
PORT=8002

# Redis (уже работает в инфраструктуре)
REDIS_URL=redis://localhost:6379/1
REDIS_PREFIX=progulkin:

# Signaling Server
SIGNALING_HOST=0.0.0.0
SIGNALING_PORT=9000

# YooKassa (получить в кабинете https://yookassa.ru)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Цены
MIN_PAYMENT_AMOUNT=10
PREMIUM_PRICE=149
